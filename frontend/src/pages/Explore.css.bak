.explore-page {
    min-height: 100vh;
    padding-top: 64px;
}

.explore-main {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
}

.explore-header {
    text-align: center;
    margin-bottom: var(--space-16);
}

.explore-header h1 {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 800;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
}

.explore-header p {
    font-size: 1.25rem;
    color: var(--gray-400);
    margin-bottom: var(--space-10);
}

/* Search Container */
.search-container {
    max-width: 700px;
    margin: 0 auto var(--space-8);
    padding: 0 var(--space-6);
    display: flex;
    align-items: center;
    background: var(--surface-glass);
    border: 1px solid var(--surface-glass-border);
    border-radius: var(--radius-full);
    height: 64px;
    transition: var(--transition-base);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
}

.search-container:focus-within {
    border-color: var(--primary-500);
    transform: translateY(-2px);
    box-shadow: 0 15px 50px rgba(234, 179, 8, 0.15);
}

.search-icon {
    color: var(--primary-400);
    font-size: 1.5rem;
    margin-right: var(--space-4);
}

.search-container input {
    flex: 1;
    background: none;
    border: none;
    color: white;
    font-size: 1.1rem;
    outline: none;
}

/* Category Filter */
.category-filter {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
}

.category-chip {
    padding: var(--space-2) var(--space-6);
    background: var(--surface-glass);
    border: 1px solid var(--surface-glass-border);
    border-radius: var(--radius-full);
    color: var(--gray-300);
    font-weight: 600;
    transition: var(--transition-base);
    cursor: pointer;
}

.category-chip:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
}

.category-chip.active {
    background: var(--gradient-primary);
    border-color: transparent;
    color: white;
    box-shadow: var(--shadow-primary);
}

/* Destination Grid */
.destinations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-8);
}

.dest-card {
    border-radius: var(--radius-2xl);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    flex-direction: column;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    position: relative;
}

.dest-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 2px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 50%, rgba(255, 255, 255, 0) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0.5;
    transition: opacity 0.4s ease;
}

.dest-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(99, 102, 241, 0.15);
    border-color: rgba(255, 255, 255, 0.15);
}

.dest-card:hover::before {
    opacity: 1;
    background: linear-gradient(135deg, var(--primary-400) 0%, transparent 50%, var(--primary-600) 100%);
}

.dest-image {
    position: relative;
    height: 240px;
    overflow: hidden;
}

.dest-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.dest-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, 0.8) 100%);
    opacity: 0.8;
}

.dest-card:hover .dest-image img {
    transform: scale(1.15) rotate(2deg);
}

.dest-tag {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    padding: var(--space-1) var(--space-4);
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    color: white;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
}

.dest-info {
    padding: var(--space-6);
    flex: 1;
    display: flex;
    flex-direction: column;
}

.dest-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-1);
}

.dest-info h3 {
    font-size: 1.25rem;
    color: white;
    font-weight: 700;
}

.dest-rating {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    background: rgba(234, 179, 8, 0.1);
    color: var(--primary-400);
    padding: 2px 8px;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
}

.dest-location {
    font-size: 0.9rem;
    color: var(--primary-400);
    margin-bottom: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-1);
}

.dest-desc {
    color: var(--gray-400);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: var(--space-6);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.dest-meta {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-4);
    border-top: 1px solid var(--surface-glass-border);
}

.dest-meta span {
    font-size: 0.9rem;
    color: var(--gray-300);
    display: flex;
    align-items: center;
    gap: var(--space-2);
}

.view-btn {
    padding: var(--space-2) var(--space-5);
    background: rgba(255, 255, 255, 0.05);
    color: var(--primary-300);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 700;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: var(--space-2);
}

.dest-card:hover .view-btn {
    background: var(--gradient-primary);
    color: white;
    border-color: transparent;
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
    transform: scale(1.05);
}

/* Modal */
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
}

.modal-content {
    width: 100%;
    max-width: 1100px;
    height: 85vh;
    background: var(--surface-glass);
    border: 1px solid var(--surface-glass-border);
    border-radius: var(--radius-3xl);
    overflow: hidden;
    position: relative;
    display: flex;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.7);
}

.close-modal {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: white;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: var(--transition-base);
}

.close-modal:hover {
    background: var(--error);
}

.modal-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    width: 100%;
    height: 100%;
}

.modal-image {
    height: 100%;
}

.modal-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.modal-body {
    padding: var(--space-8) var(--space-10);
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(2, 6, 23, 0.98) 100%);
    overflow-y: auto;
    height: 100%;
    scrollbar-width: thin;
    scrollbar-color: var(--primary-500) rgba(255, 255, 255, 0.05);
}

.modal-body::-webkit-scrollbar {
    width: 6px;
}

.modal-body::-webkit-scrollbar-thumb {
    background: var(--primary-500);
    border-radius: 6px;
}

.modal-body::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
}

.badge-primary {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: var(--primary-900);
    color: var(--primary-300);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: var(--space-4);
}

.modal-body h2 {
    font-size: 2.5rem;
    color: white;
    margin-bottom: var(--space-2);
}

.region-name {
    color: var(--primary-400);
    font-weight: 600;
    margin-bottom: var(--space-8);
}

.modal-section {
    margin-bottom: var(--space-8);
}

.modal-section h4 {
    color: white;
    margin-bottom: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-2);
}

.modal-section p {
    color: var(--gray-400);
    line-height: 1.7;
}

.info-box {
    background: rgba(255, 255, 255, 0.05);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border-left: 4px solid var(--primary-500);
}

.modal-footer-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
}

.stat-item {
    padding: var(--space-4);
    background: rgba(255, 255, 255, 0.03);
    border-radius: var(--radius-xl);
}

.stat-item .label {
    display: block;
    font-size: 0.75rem;
    color: var(--gray-500);
    text-transform: uppercase;
    margin-bottom: var(--space-1);
}

.stat-item .value {
    font-size: 1.25rem;
    color: white;
    font-weight: 700;
}

.map-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    flex: 1;
    padding: var(--space-4);
    background: var(--gradient-primary);
    color: white;
    border-radius: var(--radius-xl);
    font-weight: 700;
    transition: var(--transition-base);
}

.map-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-primary);
}

.modal-actions {
    display: flex;
    gap: var(--space-4);
    margin: var(--space-6) 0;
}

.share-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    color: var(--gray-400);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-base);
}

.share-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
}

.reviews-section {
    margin-top: var(--space-10);
}

.review-input {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-2);
    margin-bottom: var(--space-6);
}

.review-input input {
    flex: 1;
    background: transparent;
    border: none;
    color: white;
    padding: var(--space-2);
    outline: none;
}

.review-input button {
    background: var(--primary-600);
    color: white;
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-lg);
    font-weight: 600;
    cursor: pointer;
}

.review-item {
    background: rgba(255, 255, 255, 0.02);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-3);
}

.review-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-2);
}

.review-meta strong {
    color: var(--primary-300);
    font-size: 0.9rem;
}

.stars {
    font-size: 0.8rem;
}

.review-item p {
    font-size: 0.9rem !important;
    color: var(--gray-400);
}

/* Favorites Toggle */
.fav-btn {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    cursor: pointer;
    transition: var(--transition-base);
    z-index: 10;
}

.fav-btn:hover {
    transform: scale(1.1);
    background: rgba(15, 23, 42, 0.8);
}

.fav-btn.active {
    color: #ff4757;
    background: white !important;
    border-color: #ff4757;
    box-shadow: 0 0 15px rgba(255, 71, 87, 0.4);
}

/* Weather Summary */
.weather-summary {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    margin-bottom: var(--space-6);
    background: rgba(234, 179, 8, 0.05);
    border: 1px solid rgba(234, 179, 8, 0.1);
    width: fit-content;
    border-radius: var(--radius-lg);
}

.weather-summary svg {
    font-size: 1.5rem;
    color: #feba12;
}

.weather-info {
    display: flex;
    flex-direction: column;
}

.weather-info .temp {
    font-weight: 800;
    color: white;
    font-size: 1.1rem;
}

.weather-info .condition {
    font-size: 0.8rem;
    color: var(--gray-400);
}

.rating-select {
    display: flex;
    gap: var(--space-1);
    margin-bottom: var(--space-3);
}

.rating-select svg {
    cursor: pointer;
    font-size: 1.2rem;
    transition: var(--transition-base);
}

.star-active {
    color: #feba12;
}

.star-inactive {
    color: var(--gray-600);
}

.input-row {
    display: flex;
    gap: var(--space-2);
}

.no-reviews {
    color: var(--gray-500);
    text-align: center;
    padding: var(--space-4);
    font-size: 0.9rem;
    font-style: italic;
}

.view-btn {
    pointer-events: none;
    /* Let the card click handle it */
}

@media (max-width: 900px) {
    .explore-header h1 {
        font-size: 2.5rem;
    }

    .modal-grid {
        display: flex;
        flex-direction: column;
    }

    .modal-image {
        height: 300px;
        flex-shrink: 0;
    }
}